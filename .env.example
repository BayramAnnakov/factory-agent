# ============================================================================
# Required
# ============================================================================

# Anthropic API key (https://console.anthropic.com/settings/keys)
# Used for Claude Managed Agents (model calls + sandbox runtime)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# Linear OAuth app access token (actor=app install, see README for setup)
LINEAR_ACCESS_TOKEN=lin_oauth_xxxxxxxx

# GitHub URL of the repo the agent will clone and work on
REPO_URL=https://github.com/your-org/your-repo.git

# GitHub Personal Access Token with repo scope (for clone + push + PR create)
# Create at: https://github.com/settings/tokens
GH_TOKEN=ghp_xxxxxxxx

# ============================================================================
# Optional
# ============================================================================

# Linear webhook signing secret (recommended for production)
# Found in Linear app settings → Webhooks
LINEAR_WEBHOOK_SECRET=

# Linear OAuth client credentials (only needed if using the /install OAuth flow
# to install the app as an assignable agent on a Linear workspace)
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=

# Short human-readable description of your project. Passed to the agent as
# context in the task message. Example: "the Acme Analytics landing page".
# Defaults to "the project".
PROJECT_DESCRIPTION=the project

# Public URL where this server is reachable (used for OAuth callback and
# webhook registration). Example: https://factory-agent.fly.dev
# Defaults to http://localhost:$PORT
PUBLIC_URL=

# Server port (default 3457)
PORT=3457
